# Smithery WebSocket URL (update with your actual URL after deployment)
MCP_SERVER_URL=wss://custom-mcp-server.smithery.ai

# Authentication token (update with your actual token)
MCP_AUTH_TOKEN=your_smithery_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Logging level
LOG_LEVEL=INFO 